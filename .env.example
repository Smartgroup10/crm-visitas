# ─────────────────────────────────────────────────────────────
# CRM Visitas — Variables de entorno
# ─────────────────────────────────────────────────────────────
# 1. Copia este archivo como .env  (o .env.local) antes de arrancar
#       cp .env.example .env
# 2. Rellena TODOS los valores vacíos. El stack no arranca si faltan.
# 3. Arranca el stack:
#       docker compose up -d --build
# ─────────────────────────────────────────────────────────────

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=crm
POSTGRES_USER=crm
# OBLIGATORIO — elige una contraseña fuerte. Genera una con:
#   openssl rand -base64 32
POSTGRES_PASSWORD=

# ─── Backend / JWT ───────────────────────────────────────────
# OBLIGATORIO — mínimo 32 caracteres. Genera una con:
#   openssl rand -base64 48
JWT_SECRET=

# ─── Usuario administrador inicial ───────────────────────────
# Se crea automáticamente la primera vez si no hay usuarios.
# Luego puedes crear más usuarios desde la propia app o por SQL.
# OBLIGATORIO rellenarlos: si los dejas vacíos el admin no se siembra.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrador

# ─── CORS ────────────────────────────────────────────────────
# Si el frontend está en el mismo dominio que el backend (a través
# del nginx proxy de este docker-compose), deja "*".
# Si los sirves en dominios diferentes, pon aquí la URL del frontend:
#   CORS_ORIGIN=https://crm.tudominio.com
CORS_ORIGIN=*

# ─── Puerto expuesto por el contenedor del frontend ─────────
APP_PORT=9090

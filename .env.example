# ─────────────────────────────────────────────────────────────
# CRM Visitas — Variables de entorno
# ─────────────────────────────────────────────────────────────
# 1. Copia este archivo como .env  (o .env.local) antes de arrancar
#       cp .env.example .env
# 2. Rellena todos los valores marcados como "cambiar"
# 3. Arranca el stack:
#       docker compose up -d --build
# ─────────────────────────────────────────────────────────────

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=crm
POSTGRES_USER=crm
# OBLIGATORIO — elige una contraseña fuerte
POSTGRES_PASSWORD=cambiar-esta-contrasena

# ─── Backend / JWT ───────────────────────────────────────────
# OBLIGATORIO — mínimo 32 caracteres. Genera uno con:
#   openssl rand -base64 48
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio-de-al-menos-32-caracteres

# ─── Usuario administrador inicial ───────────────────────────
# Se crea automáticamente la primera vez si no hay usuarios.
# Luego puedes crear más usuarios desde la propia app o por SQL.
ADMIN_EMAIL=admin@smartgroup.es
ADMIN_PASSWORD=cambiar-esta-password
ADMIN_NAME=Administrador

# ─── CORS ────────────────────────────────────────────────────
# Si el frontend está en el mismo dominio que el backend (a través
# del nginx proxy de este docker-compose), deja "*".
# Si los sirves en dominios diferentes, pon aquí la URL del frontend:
#   CORS_ORIGIN=https://crm.tudominio.com
CORS_ORIGIN=*

# ─── Puerto expuesto por el contenedor del frontend ─────────
APP_PORT=9090
